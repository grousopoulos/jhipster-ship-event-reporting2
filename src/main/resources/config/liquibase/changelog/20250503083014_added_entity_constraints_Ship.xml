<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <!--
        Added the constraints for entity Ship.
    -->
    <changeSet id="20250503083014-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="owner_country_id"
                                 baseTableName="ship"
                                 constraintName="fk_ship__owner_country_id"
                                 referencedColumnNames="id"
                                 referencedTableName="country"
                                 />

        <addForeignKeyConstraint baseColumnNames="flag_id"
                                 baseTableName="ship"
                                 constraintName="fk_ship__flag_id"
                                 referencedColumnNames="id"
                                 referencedTableName="flag"
                                 />

        <addForeignKeyConstraint baseColumnNames="classification_society_id"
                                 baseTableName="ship"
                                 constraintName="fk_ship__classification_society_id"
                                 referencedColumnNames="id"
                                 referencedTableName="classification_society"
                                 />
    </changeSet>
</databaseChangeLog>
